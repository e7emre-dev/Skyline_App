<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/main"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:gravity="center_vertical"
		android:orientation="vertical">
		<LinearLayout
			android:id="@+id/popup_layout"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:orientation="horizontal">
			<androidx.cardview.widget.CardView
				android:id="@+id/menu_card"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginLeft="56dp"
				android:layout_marginTop="75dp"
				android:layout_marginRight="56dp"
				android:layout_marginBottom="75dp"
				app:cardElevation="1dp"
				app:cardCornerRadius="14dp">
				<LinearLayout
					android:id="@+id/body"
					android:layout_width="185dp"
					android:layout_height="wrap_content"
					android:background="#FFFFFF"
					android:orientation="vertical">
					<LinearLayout
						android:id="@+id/edit"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:paddingLeft="8dp"
						android:paddingTop="6dp"
						android:paddingRight="8dp"
						android:paddingBottom="6dp"
						android:background="#FFFFFF"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<ImageView
							android:id="@+id/edit_icon"
							android:focusable="false"
							android:layout_width="38dp"
							android:layout_height="38dp"
							android:padding="8dp"
							android:src="@drawable/my_prf_ics_1"
							android:scaleType="fitCenter" />
						<TextView
							android:id="@+id/edit_title"
							android:focusable="false"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:textSize="20sp"
							android:textColor="#000000"
							tools:replace="android:text"
							android:text="@string/m_edit" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/reply"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:paddingLeft="8dp"
						android:paddingTop="6dp"
						android:paddingRight="8dp"
						android:paddingBottom="6dp"
						android:background="#FFFFFF"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<ImageView
							android:id="@+id/reply_icon"
							android:focusable="false"
							android:layout_width="38dp"
							android:layout_height="38dp"
							android:padding="8dp"
							android:src="@drawable/popup_ic_1"
							android:scaleType="fitCenter" />
						<TextView
							android:id="@+id/reply_title"
							android:focusable="false"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:textSize="20sp"
							android:textColor="#000000"
							tools:replace="android:text"
							android:text="@string/m_reply" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/copy"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:paddingLeft="8dp"
						android:paddingTop="6dp"
						android:paddingRight="8dp"
						android:paddingBottom="6dp"
						android:background="#FFFFFF"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<ImageView
							android:id="@+id/copy_icon"
							android:focusable="false"
							android:layout_width="38dp"
							android:layout_height="38dp"
							android:padding="8dp"
							android:src="@drawable/popup_ic_2"
							android:scaleType="fitCenter" />
						<TextView
							android:id="@+id/copy_title"
							android:focusable="false"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:textSize="20sp"
							android:textColor="#000000"
							tools:replace="android:text"
							android:text="@string/m_copy" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/delete"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:paddingLeft="8dp"
						android:paddingTop="6dp"
						android:paddingRight="8dp"
						android:paddingBottom="6dp"
						android:background="#FFFFFF"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<ImageView
							android:id="@+id/delete_icon"
							android:focusable="false"
							android:layout_width="38dp"
							android:layout_height="38dp"
							android:padding="8dp"
							android:src="@drawable/popup_ic_3"
							android:scaleType="fitCenter" />
						<TextView
							android:id="@+id/delete_title"
							android:focusable="false"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:textSize="20sp"
							android:textColor="#000000"
							tools:replace="android:text"
							android:text="@string/m_delete" />
					</LinearLayout>
				</LinearLayout>
			</androidx.cardview.widget.CardView>
		</LinearLayout>
	</LinearLayout>
</LinearLayout>
