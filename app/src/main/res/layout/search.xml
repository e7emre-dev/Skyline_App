<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/body"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="#FFFFFF"
		android:orientation="vertical">
		<LinearLayout
			android:id="@+id/middleLayout"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:background="#F5F5F5"
			android:orientation="vertical"
			android:layout_weight="1">
			<LinearLayout
				android:id="@+id/topLayout"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="#FFFFFF"
				android:orientation="vertical">
				<LinearLayout
					android:id="@+id/topLayoutBar"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:gravity="center_horizontal|center_vertical"
					android:orientation="horizontal">
					<ImageView
						android:id="@+id/topLayoutBarBack"
						android:layout_width="48dp"
						android:layout_height="48dp"
						android:padding="12dp"
						android:src="@drawable/ic_arrow_back_black"
						android:scaleType="centerCrop" />
					<TextView
						android:id="@+id/topLayoutBarTitle"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:gravity="center_horizontal|center_vertical"
						android:textSize="20sp"
						android:textStyle="bold"
						android:textColor="#000000"
						android:layout_weight="1"
						tools:replace="android:text"
						android:text="@string/explore" />
					<ImageView
						android:id="@+id/topLayoutBarImgSpc"
						android:layout_width="48dp"
						android:layout_height="48dp"
						android:padding="12dp"
						android:src="@drawable/ic_arrow_back_black"
						android:scaleType="centerCrop"
						android:alpha="0.0" />
				</LinearLayout>
				<LinearLayout
					android:id="@+id/topLayoutBarMiddle"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical">
					<LinearLayout
						android:id="@+id/topLayoutBarMiddleSearchLayout"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginLeft="18dp"
						android:layout_marginRight="18dp"
						android:layout_marginBottom="18dp"
						android:paddingLeft="14dp"
						android:paddingTop="12dp"
						android:paddingRight="18dp"
						android:paddingBottom="12dp"
						android:background="#F5F5F5"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<ImageView
							android:id="@+id/topLayoutBarMiddleSearchLayoutCancel"
							android:layout_width="26dp"
							android:layout_height="26dp"
							android:layout_marginRight="4dp"
							android:padding="2dp"
							android:src="@drawable/ic_clear_black"
							android:scaleType="centerCrop" />
						<EditText
							android:id="@+id/topLayoutBarMiddleSearchInput"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_marginLeft="4dp"
							android:padding="4dp"
							android:background="@android:color/transparent"
							android:textSize="18sp"
							android:textColor="#000000"
							android:textColorHint="#757575"
							android:singleLine="true"
							android:imeOptions="actionSearch"
							android:layout_weight="1"
							tools:replace="android:hint"
							android:hint="@string/search" />
						<ImageView
							android:id="@+id/topLayoutBarMiddleSearchLayoutIc"
							android:layout_width="26dp"
							android:layout_height="26dp"
							android:layout_marginLeft="8dp"
							android:padding="2dp"
							android:src="@drawable/bottom_bar_icons_4"
							android:scaleType="centerInside" />
					</LinearLayout>
				</LinearLayout>
			</LinearLayout>
			<LinearLayout
				android:id="@+id/SearchUserLayout"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:orientation="vertical">
				<androidx.recyclerview.widget.RecyclerView
					android:id="@+id/SearchUserLayoutRecyclerView"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					tools:listitem="@layout/skyline_users_list_custom" />
				<TextView
					android:id="@+id/SearchUserLayoutNoUserFound"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:padding="8dp"
					android:gravity="center_horizontal|center_vertical"
					android:textSize="18sp"
					android:textColor="#757575"
					tools:replace="android:text"
					android:text="@string/no_user_found" />
			</LinearLayout>
		</LinearLayout>
		<LinearLayout
			android:id="@+id/bottomSpc"
			android:layout_width="match_parent"
			android:layout_height="1dp"
			android:padding="8dp"
			android:background="#F5F5F5"
			android:orientation="horizontal" />
		<LinearLayout
			android:id="@+id/bottomBar"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal">
			<LinearLayout
				android:id="@+id/bottom_home"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="10dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical"
				android:layout_weight="1">
				<ImageView
					android:id="@+id/bottom_home_ic"
					android:layout_width="30dp"
					android:layout_height="30dp"
					android:src="@drawable/bottom_bar_icons_1"
					android:scaleType="centerInside" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/bottom_search"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="10dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical"
				android:layout_weight="1">
				<ImageView
					android:id="@+id/bottom_search_ic"
					android:layout_width="30dp"
					android:layout_height="30dp"
					android:src="@drawable/bottom_bar_icons_3"
					android:scaleType="centerInside" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/bottom_videos"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="10dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical"
				android:layout_weight="1">
				<ImageView
					android:id="@+id/bottom_videos_ic"
					android:layout_width="30dp"
					android:layout_height="30dp"
					android:src="@drawable/bottom_bar_icons_6"
					android:scaleType="centerInside" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/bottom_chats"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="10dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical"
				android:layout_weight="1">
				<ImageView
					android:id="@+id/bottom_chats_ic"
					android:layout_width="30dp"
					android:layout_height="30dp"
					android:src="@drawable/bottom_bar_icons_8"
					android:scaleType="centerInside" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/bottom_profile"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="10dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical"
				android:layout_weight="1">
				<ImageView
					android:id="@+id/bottom_profile_ic"
					android:layout_width="30dp"
					android:layout_height="30dp"
					android:src="@drawable/bottom_bar_icons_10"
					android:scaleType="centerInside" />
			</LinearLayout>
		</LinearLayout>
	</LinearLayout>
</LinearLayout>
