<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/body"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:padding="16dp"
		android:background="#FFFFFF"
		android:gravity="center_horizontal|center_vertical"
		android:orientation="vertical">
		<ImageView
			android:id="@+id/icon"
			android:layout_width="110dp"
			android:layout_height="110dp"
			android:layout_marginBottom="24dp"
			android:src="@drawable/icon"
			android:scaleType="centerInside" />
		<TextView
			android:id="@+id/title"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginBottom="24dp"
			android:padding="8dp"
			android:textSize="20sp"
			android:textStyle="bold"
			android:textColor="#000000"
			tools:replace="android:text"
			android:text="@string/login_skyline_community" />
		<LinearLayout
			android:id="@+id/sign_email_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="16dp"
			android:background="#FFFFFF"
			android:gravity="center_vertical"
			android:orientation="horizontal">
			<ImageView
				android:id="@+id/sign_email_button_ic"
				android:layout_width="48dp"
				android:layout_height="48dp"
				android:padding="13dp"
				android:src="@drawable/email_ic"
				android:scaleType="fitCenter" />
			<TextView
				android:id="@+id/sign_email_button_title"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:background="@android:color/transparent"
				android:gravity="center_horizontal|center_vertical"
				android:textSize="18sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:layout_weight="1"
				tools:replace="android:text"
				android:text="@string/sign_with_email" />
			<ImageView
				android:id="@+id/sign_email_button_spx"
				android:layout_width="48dp"
				android:layout_height="48dp"
				android:padding="14dp"
				android:src="@drawable/default_image"
				android:scaleType="fitCenter"
				android:alpha="0.0" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/sign_google_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="16dp"
			android:background="#FFFFFF"
			android:gravity="center_vertical"
			android:orientation="horizontal">
			<ImageView
				android:id="@+id/sign_google_button_ic"
				android:layout_width="48dp"
				android:layout_height="48dp"
				android:padding="13dp"
				android:src="@drawable/google_ic"
				android:scaleType="fitCenter" />
			<TextView
				android:id="@+id/sign_google_button_title"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:background="@android:color/transparent"
				android:gravity="center_horizontal|center_vertical"
				android:textSize="18sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:layout_weight="1"
				tools:replace="android:text"
				android:text="@string/sign_with_google" />
			<ImageView
				android:id="@+id/sign_google_button_spx"
				android:layout_width="48dp"
				android:layout_height="48dp"
				android:padding="14dp"
				android:src="@drawable/default_image"
				android:scaleType="fitCenter"
				android:alpha="0.0" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/terms_and_conditions"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="16dp"
			android:gravity="center_vertical"
			android:orientation="horizontal">
			<ImageView
				android:id="@+id/terms_and_conditions_checkbox"
				android:layout_width="22dp"
				android:layout_height="22dp"
				android:layout_marginRight="12dp"
				android:src="@drawable/checkbox_not_checked"
				android:scaleType="centerInside" />
			<TextView
				android:id="@+id/terms_and_conditions_checkbox_title"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:textSize="16sp"
				android:textStyle="bold"
				android:textColor="#000000"
				tools:replace="android:text"
				android:text="@string/i_accept_terms_conditions" />
		</LinearLayout>
		<TextView
			android:id="@+id/create_account_email"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:paddingLeft="14dp"
			android:paddingTop="12dp"
			android:paddingRight="14dp"
			android:paddingBottom="12dp"
			android:background="#2196F3"
			android:gravity="center_horizontal|center_vertical"
			android:textSize="18sp"
			android:textStyle="bold"
			android:textColor="#FFFFFF"
			tools:replace="android:text"
			android:text="@string/create_account" />
	</LinearLayout>
</LinearLayout>
