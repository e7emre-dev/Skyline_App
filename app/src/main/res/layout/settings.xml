<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/body"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="#FAFAFA"
		android:orientation="vertical">
		<LinearLayout
			android:id="@+id/top"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:background="#FFFFFF"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="horizontal">
			<ImageView
				android:id="@+id/mBack"
				android:layout_width="48dp"
				android:layout_height="48dp"
				android:padding="12dp"
				android:src="@drawable/ic_arrow_back_black"
				android:scaleType="fitCenter" />
			<TextView
				android:id="@+id/mTitle"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginLeft="8dp"
				android:layout_marginRight="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:textSize="18sp"
				android:textStyle="bold"
				android:textColor="#000000"
				android:layout_weight="1"
				tools:replace="android:text"
				android:text="@string/settings" />
			<ImageView
				android:id="@+id/spc"
				android:layout_width="48dp"
				android:layout_height="48dp"
				android:padding="12dp"
				android:src="@drawable/default_image"
				android:scaleType="fitCenter"
				android:alpha="0.0" />
		</LinearLayout>
		<ScrollView
			android:id="@+id/scrollMain"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:scrollbars="none">
			<LinearLayout
				android:id="@+id/scrollBody"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical">
				<LinearLayout
					android:id="@+id/profile_stage"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:paddingTop="28dp"
					android:paddingBottom="28dp"
					android:gravity="center_horizontal|center_vertical"
					android:orientation="vertical">
					<androidx.cardview.widget.CardView
						android:id="@+id/profile_image_card"
						android:layout_width="125dp"
						android:layout_height="125dp"
						app:cardElevation="0dp">
						<ImageView
							android:id="@+id/profile_image_view"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:src="@drawable/avatar"
							android:scaleType="centerCrop" />
					</androidx.cardview.widget.CardView>
					<LinearLayout
						android:id="@+id/profile_details"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginTop="16dp"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<TextView
							android:id="@+id/profile_nickname"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="Nick Name"
							android:textSize="25sp"
							android:textStyle="bold"
							android:textColor="#000000"
							android:singleLine="true"
							android:maxWidth="250dp" />
						<ImageView
							android:id="@+id/profile_gender"
							android:layout_width="20dp"
							android:layout_height="20dp"
							android:layout_marginLeft="8dp"
							android:src="@drawable/male_badge"
							android:scaleType="centerInside" />
						<androidx.cardview.widget.CardView
							android:id="@+id/profile_flag_card"
							android:layout_width="28dp"
							android:layout_height="18dp"
							android:layout_marginLeft="8dp"
							app:cardElevation="0dp"
							app:cardCornerRadius="4dp">
							<ImageView
								android:id="@+id/profile_flag_image"
								android:layout_width="match_parent"
								android:layout_height="match_parent"
								android:src="@drawable/default_image"
								android:scaleType="centerCrop" />
						</androidx.cardview.widget.CardView>
					</LinearLayout>
					<TextView
						android:id="@+id/profile_username"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="Username"
						android:textSize="16sp"
						android:textColor="#616161" />
				</LinearLayout>
				<TextView
					android:id="@+id/application_stage_title"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginLeft="22dp"
					android:layout_marginRight="14dp"
					android:layout_marginBottom="8dp"
					android:textSize="16sp"
					android:textColor="#757575"
					tools:replace="android:text"
					android:text="@string/settings_application_t" />
				<LinearLayout
					android:id="@+id/application_stage"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginLeft="12dp"
					android:layout_marginRight="12dp"
					android:layout_marginBottom="14dp"
					android:paddingTop="8dp"
					android:paddingBottom="8dp"
					android:background="#FFFFFF"
					android:orientation="vertical">
					<LinearLayout
						android:id="@+id/application_stage_themes"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginLeft="8dp"
						android:layout_marginRight="8dp"
						android:paddingLeft="8dp"
						android:paddingTop="10dp"
						android:paddingRight="8dp"
						android:paddingBottom="10dp"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<ImageView
							android:id="@+id/application_stage_themes_ic"
							android:layout_width="38dp"
							android:layout_height="38dp"
							android:layout_marginRight="16dp"
							android:padding="8dp"
							android:background="#F5F5F5"
							android:src="@drawable/baseline_palette_black_48dp"
							android:scaleType="centerInside" />
						<TextView
							android:id="@+id/application_stage_themes_title"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:textSize="18sp"
							android:textStyle="bold"
							android:textColor="#000000"
							tools:replace="android:text"
							android:text="@string/settings_theme_t" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/application_stage_language"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginLeft="8dp"
						android:layout_marginRight="8dp"
						android:paddingLeft="8dp"
						android:paddingTop="10dp"
						android:paddingRight="8dp"
						android:paddingBottom="10dp"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<ImageView
							android:id="@+id/application_stage_language_ic"
							android:layout_width="38dp"
							android:layout_height="38dp"
							android:layout_marginRight="16dp"
							android:padding="8dp"
							android:background="#F5F5F5"
							android:src="@drawable/baseline_translate_black_48dp"
							android:scaleType="centerInside" />
						<TextView
							android:id="@+id/application_stage_language_title"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:textSize="18sp"
							android:textStyle="bold"
							android:textColor="#000000"
							tools:replace="android:text"
							android:text="@string/settings_language_t" />
					</LinearLayout>
				</LinearLayout>
				<TextView
					android:id="@+id/account_stage_title"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginLeft="22dp"
					android:layout_marginRight="16dp"
					android:layout_marginBottom="8dp"
					android:textSize="16sp"
					android:textColor="#757575"
					tools:replace="android:text"
					android:text="@string/settings_account_t" />
				<LinearLayout
					android:id="@+id/account_stage"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginLeft="12dp"
					android:layout_marginRight="12dp"
					android:layout_marginBottom="14dp"
					android:paddingTop="8dp"
					android:paddingBottom="8dp"
					android:background="#FFFFFF"
					android:orientation="vertical">
					<LinearLayout
						android:id="@+id/account_stage_privacy"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginLeft="8dp"
						android:layout_marginRight="8dp"
						android:paddingLeft="8dp"
						android:paddingTop="10dp"
						android:paddingRight="8dp"
						android:paddingBottom="10dp"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<ImageView
							android:id="@+id/account_stage_privacy_ic"
							android:layout_width="38dp"
							android:layout_height="38dp"
							android:layout_marginRight="16dp"
							android:padding="8dp"
							android:background="#F5F5F5"
							android:src="@drawable/baseline_lock_black_48dp"
							android:scaleType="centerInside" />
						<TextView
							android:id="@+id/account_stage_privacy_title"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:textSize="18sp"
							android:textStyle="bold"
							android:textColor="#000000"
							tools:replace="android:text"
							android:text="@string/settings_privacy_t" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/account_stage_security"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginLeft="8dp"
						android:layout_marginRight="8dp"
						android:paddingLeft="8dp"
						android:paddingTop="10dp"
						android:paddingRight="8dp"
						android:paddingBottom="10dp"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<ImageView
							android:id="@+id/account_stage_security_ic"
							android:layout_width="38dp"
							android:layout_height="38dp"
							android:layout_marginRight="16dp"
							android:padding="8dp"
							android:background="#F5F5F5"
							android:src="@drawable/baseline_security_black_48dp"
							android:scaleType="centerInside" />
						<TextView
							android:id="@+id/account_stage_security_title"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:textSize="18sp"
							android:textStyle="bold"
							android:textColor="#000000"
							tools:replace="android:text"
							android:text="@string/settings_security_t" />
					</LinearLayout>
						<LinearLayout
							android:id="@+id/account_stage_premium"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginLeft="8dp"
							android:layout_marginRight="8dp"
							android:paddingLeft="8dp"
							android:paddingTop="10dp"
							android:paddingRight="8dp"
							android:paddingBottom="10dp"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<ImageView
								android:id="@+id/account_stage_premium_ic"
								android:layout_width="38dp"
								android:layout_height="38dp"
								android:layout_marginRight="16dp"
								android:padding="8dp"
								android:background="#FFF8E1"
								android:src="@drawable/premium_badge"
								android:scaleType="centerInside" />
							<TextView
								android:id="@+id/account_stage_premium_title"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:textSize="18sp"
								android:textStyle="bold"
								android:textColor="#FF8F00"
								tools:replace="android:text"
								android:text="Skyline Premium" />
						</LinearLayout>
						<LinearLayout
							android:id="@+id/account_stage_logout"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginLeft="8dp"
						android:layout_marginRight="8dp"
						android:paddingLeft="8dp"
						android:paddingTop="10dp"
						android:paddingRight="8dp"
						android:paddingBottom="10dp"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<ImageView
							android:id="@+id/account_stage_logout_ic"
							android:layout_width="38dp"
							android:layout_height="38dp"
							android:layout_marginRight="16dp"
							android:padding="8dp"
							android:background="#F5F5F5"
							android:src="@drawable/baseline_logout_black_48dp"
							android:scaleType="centerInside" />
						<TextView
							android:id="@+id/account_stage_logout_title"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:textSize="18sp"
							android:textStyle="bold"
							android:textColor="#000000"
							tools:replace="android:text"
							android:text="@string/settings_logout_t" />
					</LinearLayout>
				</LinearLayout>
			</LinearLayout>
		</ScrollView>
	</LinearLayout>
</LinearLayout>
